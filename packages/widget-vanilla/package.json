{
  "name": "@opencheckout/widget",
  "version": "0.0.1",
  "description": "OpenCheckout embeddable Web Components checkout widget",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "dev": "tsup --watch",
    "test:small": "vitest run --reporter=verbose",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "es-hangul": "^2.3.8",
    "preact": "^10.25.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "happy-dom": "^15.11.6",
    "tsup": "^8.3.5",
    "typescript": "5.7.2",
    "vitest": "3.1.1"
  }
}
