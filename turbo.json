{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "tsconfig.json", "package.json"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "tsconfig.json"]
    },
    "lint": {
      "inputs": ["src/**/*.ts", "biome.json"]
    },
    "test:small": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "vitest.config.ts"]
    },
    "test:medium": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "vitest.config.ts"]
    },
    "test:large": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "vitest.config.ts"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
